# =============================================================================
# Zephyrwerk Energy Platform — Environment Variables
# Copy this file to .env and fill in values. Never commit .env.
# =============================================================================

# --- AWS ---
AWS_REGION=eu-central-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Local dev: points boto3 at LocalStack. Leave empty in production.
AWS_ENDPOINT_URL=http://localhost:4566

# --- S3 ---
ZEPHYRWERK_AWS_BUCKET_NAME=zephyrwerk-data-lake

# --- RDS PostgreSQL ---
ZEPHYRWERK_RDS_HOST=localhost
ZEPHYRWERK_RDS_PORT=5432
ZEPHYRWERK_RDS_DB=zephyrwerk
ZEPHYRWERK_RDS_USER=zephyrwerk
ZEPHYRWERK_RDS_PASSWORD=

# --- SMARD API ---
ZEPHYRWERK_SMARD_BASE_URL=https://www.smard.de/app/chart_data

# --- Open-Meteo ---
ZEPHYRWERK_OPENMETEO_FORECAST_URL=https://api.open-meteo.com/v1/forecast
ZEPHYRWERK_OPENMETEO_HISTORY_URL=https://archive-api.open-meteo.com/v1/archive

# --- FastAPI ---
ZEPHYRWERK_API_HOST=0.0.0.0
ZEPHYRWERK_API_PORT=8000

# --- Streamlit ---
ZEPHYRWERK_DASHBOARD_API_URL=http://localhost:8000